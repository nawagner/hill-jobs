{
  "name": "hill-jobs",
  "compatibility_date": "2024-12-30",
  "main": "src/worker.ts",
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "API_BASE_URL": "https://beneficial-beauty-production.up.railway.app"
  }
}
